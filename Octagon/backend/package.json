{
  "name": "octagon-oracle-backend",
  "version": "1.0.0",
  "description": "Backend API for Octagon Oracle MMA analytics platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "verify:phase1": "node scripts/phase1-gate.js",
    "import-data": "ts-node src/scripts/importData.ts",
    "train-model": "ts-node src/scripts/trainModel.ts",
    "compute-analytics": "ts-node src/scripts/computeAnalytics.ts",
    "import-data:prod": "node dist/scripts/importData.js"
  },
  "keywords": [
    "mma",
    "ufc",
    "analytics",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "octagon-oracle": "file:..",
    "stripe": "^20.4.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
